          "Password": "secret_sauce"
        },
        "expectedResult": "Password is masked and entered"
      },
      {
        "step": 3,
        "action": "Click login button",
        "testData": {},
        "expectedResult": "User is redirected to inventory page"
      },
      {
        "step": 4,
        "action": "Verify URL contains inventory.html",
        "testData": {
          "Expected URL": "/inventory.html"
        },
        "expectedResult": "URL is https://www.saucedemo.com/inventory.html"
      }
    ],
    "testData": {
      "username": "standard_user",
      "password": "secret_sauce"
    },
