[
  {
    "id": "TC-001",
    "name": "Successful login with valid credentials",
    "objective": "Verify user can login with valid username and password",
    "preconditions": [
      "User is not logged in",
      "Browser is open"
    ],
    "steps": [
      {
        "step": 1,
        "action": "Navigate to SauceDemo login page",
        "testData": {
          "URL": "https://www.saucedemo.com/"
        },
        "expectedResult": "Login page is displayed"
      },
      {
        "step": 2,
        "action": "Enter username in username field",
        "testData": {
          "Username": "standard_user"
        },
        "expectedResult": "Username is entered"
      },
      {
        "step": 3,
        "action": "Enter password in password field",
        "testData": {
          "Password": "secret_sauce"
        },
        "expectedResult": "Password is entered"
      },
      {
        "step": 4,
        "action": "Click login button",
        "testData": {},
        "expectedResult": "User is redirected to inventory page"
      },
      {
        "step": 5,
        "action": "Verify inventory page URL and product list",
        "testData": {
          "Expected URL": "/inventory.html"
        },
        "expectedResult": "Inventory page loaded with products displayed"
      }
    ],
    "testData": {
      "username": "standard_user",
      "password": "secret_sauce"
    },
    "tags": [
      "smoke",
      "regression",
      "login"
    ],
    "priority": "High",
    "flowRef": "valid_login"
  },
