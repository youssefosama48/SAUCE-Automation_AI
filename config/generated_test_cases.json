[
  {
    "id": "TC-001",
    "name": "Valid Login with Standard User",
    "objective": "Verify registered user can login with valid credentials",
    "preconditions": [
      "Browser is open",
      "SauceDemo login page is loaded"
    ],
    "steps": [
      {
        "step": 1,
        "action": "Navigate to SauceDemo login page",
        "testData": {
          "URL": "https://www.saucedemo.com/"
        },
        "expectedResult": "Login page is displayed"
      },
      {
        "step": 2,
        "action": "Enter username in username field",
        "testData": {
          "Username": "standard_user"
        },
        "expectedResult": "Username is entered"
      },
      {
        "step": 3,
        "action": "Enter password in password field",
        "testData": {
          "Password": "secret_sauce"
        },
        "expectedResult": "Password is masked and entered"
      },
      {
        "step": 4,
        "action": "Click login button",
        "testData": {},
        "expectedResult": "User is redirected to inventory page"
      },
      {
        "step": 5,
        "action": "Verify inventory page URL",
        "testData": {
          "Expected URL": "https://www.saucedemo.com/inventory.html"
        },
        "expectedResult": "User is on inventory page"
      }
    ],
    "testData": {
      "username": "standard_user",
      "password": "secret_sauce"
    },
    "tags": [
      "smoke",
      "regression",
      "login"
    ],
    "priority": "High",
    "flowRef": "valid_login"
  },
